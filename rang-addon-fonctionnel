// REMPLACER la fonction generateLeaderboard() par celle-ci :
function generateLeaderboard() {
  const users = loadRealUsers();
  const list = document.getElementById('leaderboardList');
  const currentUserData = JSON.parse(sessionStorage.getItem('currentUser') || '{}');
  const isUserAdmin = currentUserData.role === 'admin' || currentUserData.isAdmin === true;
  
  if (users.length === 0) {
    list.innerHTML = '<div style="text-align:center;padding:32px;color:rgba(255,255,255,0.3);font-size:11px;letter-spacing:3px;text-transform:uppercase;font-family:var(--mono);">Aucun joueur classé</div>';
    return;
  }
  
  list.innerHTML = users.map((u, i) => {
    const pos = i + 1;
    const isTop = pos <= 3;
    const photo = localStorage.getItem(`scorepilot_photo_${u.userId}`);
    const avatarEl = photo
      ? `<img src="${photo}" class="student-avatar" style="object-fit:cover;"/>`
      : `<div class="student-avatar">${u.name.charAt(0).toUpperCase()}</div>`;
    const posBadge = isTop
      ? `<div class="pos-badge pos-top">${pos === 1 ? '01' : pos === 2 ? '02' : '03'}</div>`
      : `<div class="pos-badge pos-normal">${String(pos).padStart(2,'0')}</div>`;
    
    // Afficher le PIN seulement pour les admins
    const pinTag = isUserAdmin ? `
      <div class="student-rank-tag" style="background:rgba(255,70,85,0.08);border-color:rgba(255,70,85,0.2);">
        <span style="letter-spacing:1.5px;">PIN: ${u.pin}</span>
      </div>
    ` : '';
    
    return `
    <div class="leaderboard-item ${u.isMe?'me':''}" onclick='showProfile(${JSON.stringify(u).replace(/'/g,"&apos;")},${pos})'>
      ${posBadge}
      ${avatarEl}
      <div style="flex:1;min-width:0;">
        <div class="student-name">${u.name}${u.isMe?' <span style="color:rgba(255,70,85,0.7);font-size:10px;letter-spacing:2px;">(TOI)</span>':''}</div>
        <div style="display:flex;gap:8px;margin-top:4px;">
          <div class="student-rank-tag">
            <span class="lb-emblem">${buildSmallSVG(u.rank, 22)}</span>
            <span style="letter-spacing:1.5px;">${u.rank.name}</span>
          </div>
          ${pinTag}
          <div class="student-rank-tag" style="background:rgba(16,185,129,0.08);border-color:rgba(16,185,129,0.2);color:#10b981;">
            <span style="letter-spacing:1.5px;">${u.wins}V-${u.losses}D</span>
          </div>
        </div>
      </div>
      <div class="student-pts">
        <div class="student-pts-val" style="color:${u.rank.color};">${u.points}</div>
        <div class="student-pts-lbl">RR</div>
      </div>
    </div>`;
  }).join('');
}

