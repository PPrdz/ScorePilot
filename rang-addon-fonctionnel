// ========================================
// 1. RÉCUPÉRER LE PIN DEPUIS L'INSCRIPTION
// ========================================

function getUserPin(uid) {
  const userKey = `scorepilot_user_${uid}`;
  const userData = localStorage.getItem(userKey);
  
  if (userData) {
    const user = JSON.parse(userData);
    return user.pin || user.code || '—';
  }
  
  return '—';
}

// ========================================
// 2. LEADERBOARD GLOBAL (TOUS LES USERS)
// ========================================

// REMPLACER la fonction loadRealUsers() par celle-ci :
function loadRealUsers() {
  const users = [];
  
  // Scanner TOUS les utilisateurs du système
  for (let i = 0; i < localStorage.length; i++) {
    const key = localStorage.key(i);
    
    if (key.startsWith('scorepilot_user_')) {
      const uid = key.replace('scorepilot_user_', '');
      const userData = JSON.parse(localStorage.getItem(key));
      
      // Vérifier que le user existe vraiment (a un nom ou email)
      if (!userData.name && !userData.email) {
        console.log('⚠️ User fantôme ignoré:', uid);
        continue; // Ignorer les users fantômes/supprimés
      }
      
      // Récupérer les rôles actifs
      const rolesData = localStorage.getItem(`scorepilot_roles_${uid}`) || 
                       localStorage.getItem(`sp_roles_${uid}`);
      let roles = rolesData ? JSON.parse(rolesData) : [];
      roles = roles.filter(r => r.expiresAt === -1 || r.expiresAt > Date.now());
      
      // Déterminer le statut
      let status = userData.role?.toUpperCase() || userData.plan?.toUpperCase() || 'FREE';
      
      // Vérifier si c'est un admin (plusieurs façons)
      if (userData.isAdmin === true || 
          status === 'ADMIN' || 
          roles.some(r => r.role === 'ADMIN')) {
        status = 'ADMIN';
      } else if (roles.length > 0) {
        const priority = { ADMIN: 3, COLLABORATEUR: 2, PRO: 1 };
        roles.sort((a, b) => (priority[b.role] || 0) - (priority[a.role] || 0));
        status = roles[0].role;
      }
      
      console.log(`User ${userData.name} (${uid}): status=${status}`);
      
      // FILTRER : Afficher SEULEMENT PRO/COLLABORATEUR/ADMIN dans le leaderboard
      if (status !== 'PRO' && status !== 'COLLABORATEUR' && status !== 'ADMIN') {
        console.log(`  ❌ Ignoré (FREE)`);
        continue; // Ignorer les FREE
      }
      
      console.log(`  ✅ Ajouté au leaderboard`);
      
      // Récupérer les points de rang
      const rankData = JSON.parse(localStorage.getItem(`sp_rank_${uid}`) || '{}');
      const pts = rankData.points || 0;
      
      users.push({
        name: userData.name || uid,
        userId: uid,
        points: pts,
        rank: getCurrentRank(pts),
        status: status,
        pin: userData.pin || userData.code || '—',
        isMe: uid === userId,
        wins: rankData.wins || 0,
        losses: rankData.losses || 0
      });
    }
  }
  
  console.log(`📊 Total dans leaderboard: ${users.length}`);
  
  // Trier par points décroissants
  return users.sort((a, b) => b.points - a.points);
}

// ========================================
// 3. AFFICHER LE PIN DANS LE LEADERBOARD
