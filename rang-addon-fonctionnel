function saveUserData(uid) {
  const points = parseInt(document.getElementById(`points_${uid}`).value) || 0;
  const wins = parseInt(document.getElementById(`wins_${uid}`).value) || 0;
  const losses = parseInt(document.getElementById(`losses_${uid}`).value) || 0;
  
  // Mettre à jour les données de rang
  let rankData = JSON.parse(localStorage.getItem(`sp_rank_${uid}`) || '{}');
  rankData.points = points;
  rankData.wins = wins;
  rankData.losses = losses;
  rankData.totalMatches = wins + losses;
  
  const newRank = getCurrentRank(points);
  rankData.rank = newRank.name;
  rankData.icon = '—'; // Pas d'icône dans ce système
  
  localStorage.setItem(`sp_rank_${uid}`, JSON.stringify(rankData));
  
  alert(`✅ Modifications sauvegardées pour ${uid}`);
  
  // Rafraîchir
  generateLeaderboard();
  if (uid === userId) {
    updateRankDisplay();
  }
}

